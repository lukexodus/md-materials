```

js

```js
async function verifySession(request, reply) {
  const user = request.session.get('user')

  if (!user) {
    reply.code(401).send({ error: 'Not authenticated' })
  }

  request.user = user
}

app.get('/ws', {
  websocket: true,
  preHandler: verifySession
