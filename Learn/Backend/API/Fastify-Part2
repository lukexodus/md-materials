```
my-app/
├── app.js
├── package.json
├── plugins/
│   ├── 00-env.js
│   ├── 01-db.js
│   └── 02-auth.js
├── features/
│   ├── users/
│   │   ├── index.js
│   │   ├── routes.js
│   │   ├── schemas.js
│   │   ├── hooks.js
│   │   ├── service.js
│   │   └── repository.js
